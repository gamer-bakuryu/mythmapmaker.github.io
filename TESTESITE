export const assetRegistry = new Map();

export function registerAsset(file){
  const id = crypto.randomUUID();

  assetRegistry.set(id, {
    id,
    file,
    name:file.name,
    url:URL.createObjectURL(file)
  });

  return id;
}

export function getAsset(id){
  return assetRegistry.get(id);
}

