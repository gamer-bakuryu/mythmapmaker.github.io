export const layers = {
  default:{
    visible:true,
    locked:false,
    opacity:1,
    order:0,
    objects:[]
  }
};

export let currentLayer = 'default';

export function setCurrentLayer(name){
  currentLayer = name;
}

export function createLayer(name){
  if(layers[name]) return;

  layers[name] = {
    visible:true,
    locked:false,
    opacity:1,
    order:Object.keys(layers).length,
    objects:[]
  };
}

