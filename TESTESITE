import { assetRegistry } from './assets';
import { layers } from './layers';

export let dirty = false;

const DB_NAME = 'rpg_editor';
const STORE = 'scenes';

export function markDirty(){
  dirty = true;
}

export async function openDB(){
  return new Promise((resolve,reject)=>{

    const req = indexedDB.open(DB_NAME, 1);

    req.onupgradeneeded = e => {
      e.target.result.createObjectStore(STORE);
    };

    req.onsuccess = e => resolve(e.target.result);
    req.onerror = reject;
  });
}

export async function saveScene(sceneObjects){

  const db = await openDB();

  const data = {
    assets:[...assetRegistry.values()].map(a=>(
      {
        id:a.id,
        name:a.name,
        url:a.url
      }
    )),

    layers,

    objects:sceneObjects.map(o=>(
      {
        assetId:o.userData.assetId,
        layer:o.userData.layer,

        position:o.position,
        rotation:o.rotation,
        scale:o.scale
      }
    ))
  };

  return new Promise(resolve=>{

    const tx = db.transaction(STORE,'readwrite');

    tx.objectStore(STORE).put(data,'autosave');

    tx.oncomplete = ()=>{
      dirty = false;
      resolve();
    };
  });
}

export function autosaveLoop(){

  setInterval(()=>{

    if(!dirty) return;

    window.dispatchEvent(
      new CustomEvent('request-save')
    );

  }, 5000);
}

